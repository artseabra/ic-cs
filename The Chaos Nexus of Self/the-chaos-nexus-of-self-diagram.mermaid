flowchart LR
    SELF[Self-observation] --> CN[Chaos Nexus of Self]
    CN --> CORE[Identity as strange attractor]

    CORE --> O[Observer]
    O --> E[Exposure]
    E --> F[Filament]
    F --> P[Payload]
    P --> N[Nodes]
    N --> S[Substrate]
    S --> A[Archive]
    A --> O

    CORE --> D1[Fixed Point Stasis]
    D1 --> D2[Periodic Habit Loop]
    D2 --> D3[Quasiperiodic Routine Drift]
    D3 --> D4[Strange Attractor Full Nexus]
    D4 --> D5[Divergence Crisis]

    CORE --> SUB[Subconscious collapse]
    CORE --> CON[Conscious collapse]
    SUB --> PFT[Phantom Floor Threshold]
    CON --> PFT
    CON --> KICK[Stochastic kick]
    KICK --> N

    CORE --> R1[Observe choice]
    R1 --> R2[Observation changes choice]
    R2 --> R3[Changed choice changes observation]
    R3 --> R4[Changed observation changes next choice]
    R4 --> R1

    CORE --> ES1[Escape: stochastic kick]
    CORE --> ES2[Escape: leaky boundary]
    CORE --> ES3[Escape: crisis bifurcation]
    ES1 --> N
    ES2 --> N
    ES3 --> N

    CN --> CR[Conservation Razor]
    CN --> IR[Interrogation Razor]
    CR --> BOTH[Doubt what you see]
    IR --> BOTH
    BOTH --> PFT

    CN --> Q1[Archive and Observer]
    CN --> Q2[Firewall problem]
    CN --> Q3[Unnamed strings]
    CN --> Q4[Deeper unity]
    CN --> SIB[Sibling: Interrogation Collapse]
    SIB --> Q4

    classDef core fill:#2b124c,color:#ffffff,stroke:#d8b4fe,stroke-width:1.5px;
    classDef system fill:#1f2937,color:#ffffff,stroke:#93c5fd,stroke-width:1.2px;
    classDef danger fill:#3b0f0f,color:#ffffff,stroke:#fb7185,stroke-width:1.5px;
    classDef insight fill:#123524,color:#ffffff,stroke:#6ee7b7,stroke-width:1.5px;

    class SELF,CN,CORE,SIB core;
    class O,E,F,P,N,S,A,D1,D2,D3,D4,D5,SUB,CON,R1,R2,R3,R4,ES1,ES2,ES3,Q1,Q2,Q3,Q4 system;
    class PFT danger;
    class KICK,CR,IR,BOTH insight;
